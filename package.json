{
  "name": "thousand",
  "version": "1.0.0",
  "description": "Card Game 1000 — Lobby & Game Creation",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "test": "node --test tests/*.test.js",
    "test:coverage": "node --test --experimental-test-coverage tests/*.test.js",
    "dev": "node --run start -- --watch",
    "lint": "eslint src",
    "build": "node -e \"require('./src/server')\"",
    "prepare": "git config core.hooksPath .githooks || true"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "jsdom": "^25.0.0",
    "playwright": "^1.60.0"
  }
}
